---
import { experiencePath } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  slug: string;
  title: string;
  role: string;
  period: string;
  summary: string;
  stack: string[];
}

const { locale, slug, title, role, period, summary, stack } = Astro.props;
const href = experiencePath(slug, locale);
---

<article class="card group">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
    <h3 class="text-2xl font-serif font-bold tracking-tight" transition:name={`exp-title-${slug}`}>
      <a href={href} class="card-title no-underline">
        {title}
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </h3>
    <span class="text-sm text-[var(--color-muted)] whitespace-nowrap">{period}</span>
  </div>
  <p class="text-[var(--color-muted)] mb-3 italic">{role}</p>
  <p class="text-[1.05rem] leading-relaxed mb-4 max-w-2xl">{summary}</p>
  <div class="flex flex-wrap items-center gap-1.5">
    {stack.map((s) => <span class="chip">{s}</span>)}
  </div>
</article>
