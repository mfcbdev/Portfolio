---
import { experiencePath, useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  slug: string;
  title: string;
  role: string;
  period: string;
  summary: string;
  stack: string[];
}

const { locale, slug, title, role, period, summary, stack } = Astro.props;
const t = useTranslations(locale);
---

<article class="border-t border-[var(--color-rule)] py-10 first:border-t-0 first:pt-0">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
    <h3 class="text-2xl font-serif font-bold tracking-tight">
      <a href={experiencePath(slug, locale)} class="no-underline hover:text-[var(--color-accent)]">
        {title}
      </a>
    </h3>
    <span class="text-sm text-[var(--color-muted)] whitespace-nowrap">{period}</span>
  </div>
  <p class="text-[var(--color-muted)] mb-3 italic">{role}</p>
  <p class="text-[1.05rem] leading-relaxed mb-4">{summary}</p>
  <div class="flex flex-wrap items-center gap-1.5 mb-4">
    {stack.map((s) => <span class="chip">{s}</span>)}
  </div>
  <a href={experiencePath(slug, locale)} class="text-sm">{t('experience.viewCase')}</a>
</article>
