---
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  title: string;
  summary: string;
  stack: string[];
  github?: string;
  liveUrl?: string;
}

const { locale, title, summary, stack, github, liveUrl } = Astro.props;
const t = useTranslations(locale);
---

<article class="border-t border-[var(--color-rule)] py-10 first:border-t-0 first:pt-0">
  <h3 class="text-2xl font-serif font-bold tracking-tight mb-3">{title}</h3>
  <p class="text-[1.05rem] leading-relaxed mb-4">{summary}</p>
  <div class="flex flex-wrap items-center gap-1.5 mb-5">
    {stack.map((s) => <span class="chip">{s}</span>)}
  </div>
  <div class="flex flex-wrap gap-3 text-sm">
    {
      github && (
        <a href={github} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          {t('projects.code')}
        </a>
      )
    }
    {
      liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M10 2H14V6"/>
            <path d="M14 2L7.5 8.5"/>
            <path d="M12 9V13C12 13.5523 11.5523 14 11 14H3C2.44772 14 2 13.5523 2 13V5C2 4.44772 2.44772 4 3 4H7"/>
          </svg>
          {t('projects.live')}
        </a>
      )
    }
  </div>
</article>
