---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, useTranslations, alternateUrl, locales } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const { title = t('site.title'), description = t('site.description') } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eff6e0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {
      locales.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={new URL(alternateUrl(Astro.url, l), Astro.site).toString()}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(alternateUrl(Astro.url, 'es'), Astro.site).toString()}
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <ClientRouter />
  </head>
  <body>
    <Header locale={locale} />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
