---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { path } from '../../i18n/utils';

export async function getStaticPaths() {
  const all = await getCollection('experience', ({ data }) => data.locale === 'es');
  return all.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---

<Base title={`${d.title} — Matías Cavieres`} description={d.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-16 sm:pt-24">
    <a href={path('experience', 'es')} class="text-sm text-[var(--color-muted)]">« Volver a experiencia</a>
    <header class="mt-6 mb-10 border-b border-[var(--color-rule)] pb-10">
      <p class="text-sm text-[var(--color-muted)] uppercase tracking-[0.18em] mb-3">{d.period}</p>
      <h1 class="text-[var(--text-h1)] font-serif font-bold tracking-tight">{d.title}</h1>
      <p class="mt-3 text-[var(--text-lead)] text-[var(--color-muted)] italic">{d.role}</p>
      <div class="mt-6 flex flex-wrap gap-1.5">
        {d.stack.map((s) => <span class="chip">{s}</span>)}
      </div>
      {
        d.metrics && d.metrics.length > 0 && (
          <ul class="mt-6 space-y-1.5">
            {d.metrics.map((m) => (
              <li class="text-[1.05rem]">
                <span class="text-[var(--color-accent)]">›</span> {m}
              </li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose-body">
      <Content />
    </div>
  </article>
</Base>
