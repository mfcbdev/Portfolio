---
import { getCollection } from 'astro:content';
import ExperienceCard from '../components/ExperienceCard.astro';
import { useTranslations, path } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('experience', ({ data }) => data.locale === locale && data.featured);
all.sort((a, b) => a.data.order - b.data.order);
---

<section class="mx-auto max-w-3xl px-6 pb-20">
  <div class="flex items-baseline justify-between mb-10">
    <h2 class="text-[var(--text-h2)] font-serif font-bold tracking-tight">{t('home.featuredExperience')}</h2>
    <a href={path('experience', locale)} class="link-quiet text-sm text-[var(--color-muted)]">{t('home.viewAllExperience')}</a>
  </div>
  <div>
    {
      all.map((entry, i) => (
        <div class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
          <ExperienceCard
            locale={locale}
            slug={entry.data.slug}
            title={entry.data.title}
            role={entry.data.role}
            period={entry.data.period}
            summary={entry.data.summary}
            stack={entry.data.stack}
          />
        </div>
      ))
    }
  </div>
</section>
