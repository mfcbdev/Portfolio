---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import { useTranslations, path } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('projects', ({ data }) => data.locale === locale && data.featured);
all.sort((a, b) => a.data.order - b.data.order);
---

<section class="mx-auto max-w-3xl px-6 pb-24">
  <div class="flex items-baseline justify-between mb-8">
    <h2 class="text-[var(--text-h2)] font-serif font-bold tracking-tight">{t('home.featured')}</h2>
    <a href={path('projects', locale)} class="text-sm">{t('home.viewAll')}</a>
  </div>
  <div>
    {
      all.map((entry) => (
        <ProjectCard
          locale={locale}
          slug={entry.data.slug}
          title={entry.data.title}
          role={entry.data.role}
          period={entry.data.period}
          summary={entry.data.summary}
          stack={entry.data.stack}
        />
      ))
    }
  </div>
</section>
