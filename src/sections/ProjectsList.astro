---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const all = await getCollection('projects', ({ data }) => data.locale === locale);
all.sort((a, b) => a.data.order - b.data.order);
---

<section class="mx-auto max-w-3xl px-6 pt-16 sm:pt-24">
  <SectionHeading title={t('projects.title')} intro={t('projects.intro')} />
  <div>
    {
      all.map((entry, i) => (
        <div class="reveal" style={`--reveal-delay: ${200 + i * 90}ms`}>
          <ProjectCard
            locale={locale}
            title={entry.data.title}
            summary={entry.data.summary}
            stack={entry.data.stack}
            github={entry.data.github}
            liveUrl={entry.data.liveUrl}
          />
        </div>
      ))
    }
  </div>
</section>
